<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary SEO Metadata -->
    <title>Beauty Plus Academy & Salon | Salon Services & Career Training Kingston, Jamaica</title>
    <meta name="description" content="Beauty Plus Academy & Salon in Kingston, Jamaica offers professional salon services (makeup, nails, locs, braids, waxing) and accredited 8-week career certification courses." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://beautyplusacademyandsalon.com/" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://beautyplusacademyandsalon.com/" />
    <meta property="og:title" content="Beauty Plus Academy & Salon | Salon & Training" />
    <meta property="og:description" content="Professional salon services and 8-week beauty certification courses in Kingston, Jamaica. Learn makeup, nails, locs, braiding, waxing, and barbering." />
    <meta property="og:image" content="https://www.jotform.com/uploads/antwunwilson/form_files/clear_form_logo_background_colors_source_1771883276.jpg?nc=1" />
    <meta property="og:site_name" content="Beauty Plus Academy & Salon" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://beautyplusacademyandsalon.com/" />
    <meta name="twitter:title" content="Beauty Plus Academy & Salon | Salon & Training" />
    <meta name="twitter:description" content="Professional salon services and 8-week beauty certification courses in Kingston, Jamaica. Learn makeup, nails, locs, braiding, waxing, and barbering." />
    <meta name="twitter:image" content="https://www.jotform.com/uploads/antwunwilson/form_files/clear_form_logo_background_colors_source_1771883276.jpg?nc=1" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BeautySalon",
          "@id": "https://beautyplusacademyandsalon.com/#salon",
